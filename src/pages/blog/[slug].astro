---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---
<Layout title={post.data.title}>
  <article class="max-w-4xl mx-auto py-16 px-6">
    <!-- Back Button -->
    <div class="mb-8">
      <a href="/blog" class="back-button wc-card inline-flex items-center gap-3 px-6 py-3 group hover:scale-105 transition-all duration-300">
        <svg class="w-5 h-5 transition-transform duration-300 group-hover:-translate-x-1" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
        </svg>
        Back to Blog
      </a>
    </div>

    <!-- Cover Image -->
    {post.data.coverImage && (
      <div class="cover-wrap mb-4">
        <img src={post.data.coverImage} alt={post.data.title} class="cover-img" />
      </div>
    )}

    <!-- Post Header -->
    <header class="post-header wc-card p-8 mb-12">
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-gradient leading-tight mb-6">
        {post.data.title}
      </h1>
      
      <div class="flex items-center gap-4 text-sm text-neutral-400">
        <time datetime={post.data.date} class="flex items-center gap-2">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
          </svg>
          {new Date(post.data.date).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric'
          })}
        </time>
        
        {post.data.summary && (
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M3 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z" clip-rule="evenodd" />
            </svg>
            {post.data.summary}
          </span>
        )}
      </div>
    </header>

    <!-- Post Content -->
    <div class="post-content wc-card p-8 prose prose-invert prose-lg max-w-none">
      <Content />
      
      {/* Render photo layout groups */}
      {post.data.imageGroups && post.data.imageGroups.length > 0 && (
        <div class="image-groups mt-8 space-y-8">
          {post.data.imageGroups.map((group, groupIndex) => (
            <div class={`image-group layout-${group.layout}`}>
              {group.images.map((item, imageIndex) => (
                <figure class="image-item">
                  <img
                    src={item.image}
                    alt={item.alt || item.caption || `Photo ${imageIndex + 1}`}
                    loading="lazy"
                  />
                  {item.caption && (
                    <figcaption>{item.caption}</figcaption>
                  )}
                </figure>
              ))}
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- Navigation Footer -->
    <footer class="mt-12 flex justify-between">
      <a href="/blog" class="wc-card px-6 py-3 group hover:scale-105 transition-all duration-300">
        ← All Posts
      </a>
    </footer>
  </article>
</Layout>

<style>
  /* Cover image */
  .cover-wrap {
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
  }

  .cover-img {
    width: 100%;
    height: auto;
    max-height: 420px;
    object-fit: cover;
    display: block;
  }

  /* Glass card styles matching the blog index */
  .wc-card {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    box-shadow: 0 1px 0 rgba(255,255,255,0.05) inset, 0 20px 50px rgba(0,0,0,0.4);
    border-radius: 16px;
    transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .wc-card:hover {
    border-color: rgba(255,255,255,0.2);
    box-shadow: 0 25px 60px rgba(0,0,0,0.5), 0 1px 0 rgba(255,255,255,0.08) inset;
  }

  /* Back button specific styling */
  .back-button {
    text-decoration: none;
    color: inherit;
  }

  /* Post header and content animations */
  .post-header, .post-content {
    animation: fadeInUp 0.8s ease-out forwards;
  }

  .post-content {
    animation-delay: 0.2s;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Text gradient utility */
  .text-gradient {
    background: linear-gradient(135deg, #fafafa 0%, #a1a1aa 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Enhanced prose styling */
  .prose {
    color: #f6f6f6;
  }

  .prose h2, .prose h3, .prose h4 {
    color: #fafafa;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .prose p {
    margin-bottom: 1.5rem;
    line-height: 1.7;
  }

  .prose a {
    color: #fbbf24;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s ease;
  }

  .prose a:hover {
    border-bottom-color: #fbbf24;
  }

  .prose ul, .prose ol {
    margin-bottom: 1.5rem;
  }

  .prose li {
    margin-bottom: 0.5rem;
  }

  .prose blockquote {
    border-left: 4px solid #fbbf24;
    padding-left: 1.5rem;
    margin: 2rem 0;
    font-style: italic;
    color: #a1a1aa;
  }

  .prose code {
    background: rgba(255,255,255,0.1);
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    font-size: 0.9em;
  }

  .prose pre {
    background: rgba(0,0,0,0.3);
    padding: 1.5rem;
    border-radius: 8px;
    overflow-x: auto;
    margin: 2rem 0;
  }

  /* Clean, responsive image styling for local uploads */
  .prose img {
    width: 100%;
    height: auto;
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    margin: 2rem auto;
    display: block;
    max-width: 100%;
  }

  /* Ensure images are responsive */
  .prose figure {
    margin: 2rem 0;
  }

  .prose figure img {
    margin: 0;
  }

  /* Override Tailwind prose spacing with CSS custom properties */
  .prose {
    --tw-prose-spacing: 2rem;
    --tw-prose-vertical-spacing: 2rem;
  }

  /* Force more spacing between prose elements */
  .prose > * + * {
    margin-top: 2rem;
  }

  /* Extra spacing for images */
  .prose > * + img {
    margin-top: 3rem;
  }

  .prose > img + * {
    margin-top: 3rem;
  }

  /* Prevent the row-spacing rule from adding top margin inside grid cells */
  :global(.prose div.cms-photo-row figure + figure) {
    margin-top: 0;
  }

  /* Photo layout groups */
  .image-group {
    display: grid;
    gap: 0.75rem;
  }

  .image-group.layout-full {
    grid-template-columns: 1fr;
  }

  .image-group.layout-two-up {
    grid-template-columns: 1fr 1fr;
  }

  .image-group.layout-three-up {
    grid-template-columns: 1fr 1fr 1fr;
  }

  .image-group.layout-four-up {
    grid-template-columns: 1fr 1fr 1fr 1fr;
  }

  /* Stack to 2 columns on small screens */
  @media (max-width: 640px) {
    .image-group.layout-three-up,
    .image-group.layout-four-up {
      grid-template-columns: 1fr 1fr;
    }
  }

  .image-item {
    margin: 0;
  }

  .image-item img {
    width: 100%;
    height: auto;
    border-radius: 10px;
    display: block;
    object-fit: cover;
    aspect-ratio: 4 / 3;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.35);
    margin: 0;
  }

  /* Full-width images don't need forced aspect ratio */
  .layout-full .image-item img {
    aspect-ratio: unset;
    max-height: 80vh;
    object-fit: contain;
    background: rgba(0,0,0,0.2);
  }

  .image-item figcaption {
    margin-top: 0.4rem;
    font-size: 0.8rem;
    color: #888;
    text-align: center;
    font-style: italic;
  }

  /* Clear floats so the next block-level element starts fresh */
  .post-content::after {
    content: '';
    display: table;
    clear: both;
  }

  /*
   * ── cms-photo & cms-photo-row ──────────────────────────────────────────
   * These elements come from raw HTML blocks in markdown (CMS editor
   * components). Astro's scoped CSS does NOT add the cid attribute to raw
   * HTML blocks, so the rules below use :global() to match them directly.
   * ────────────────────────────────────────────────────────────────────── */

  /* ── cms-photo: single positioned photo ── */
  :global(.prose figure.cms-photo) {
    margin: 2rem 0;
  }

  :global(.prose figure.cms-photo[data-align="center"]) {
    display: block;
    margin-left:  auto;
    margin-right: auto;
  }
  :global(.prose figure.cms-photo[data-align="center"][data-size="full"])   { max-width: 100%; }
  :global(.prose figure.cms-photo[data-align="center"][data-size="large"])  { max-width: 70%;  }
  :global(.prose figure.cms-photo[data-align="center"][data-size="medium"]) { max-width: 50%;  }
  :global(.prose figure.cms-photo[data-align="center"][data-size="small"])  { max-width: 33%;  }

  :global(.prose figure.cms-photo[data-align="left"]) {
    float: left;
    margin: 0 2rem 1.5rem 0;
  }
  :global(.prose figure.cms-photo[data-align="right"]) {
    float: right;
    margin: 0 0 1.5rem 2rem;
  }
  :global(.prose figure.cms-photo[data-align="left"][data-size="full"]),
  :global(.prose figure.cms-photo[data-align="right"][data-size="full"])   { width: 100%; }
  :global(.prose figure.cms-photo[data-align="left"][data-size="large"]),
  :global(.prose figure.cms-photo[data-align="right"][data-size="large"])  { width: 70%;  }
  :global(.prose figure.cms-photo[data-align="left"][data-size="medium"]),
  :global(.prose figure.cms-photo[data-align="right"][data-size="medium"]) { width: 50%;  }
  :global(.prose figure.cms-photo[data-align="left"][data-size="small"]),
  :global(.prose figure.cms-photo[data-align="right"][data-size="small"])  { width: 33%;  }

  :global(.prose figure.cms-photo img) {
    width: 100%;
    height: auto;
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
    display: block;
    margin: 0;
  }
  :global(.prose figure.cms-photo[data-aspect="square"] img)    { aspect-ratio: 1 / 1;  object-fit: cover; }
  :global(.prose figure.cms-photo[data-aspect="landscape"] img) { aspect-ratio: 16 / 9; object-fit: cover; }
  :global(.prose figure.cms-photo[data-aspect="portrait"] img)  { aspect-ratio: 3 / 4;  object-fit: cover; }

  :global(.prose figure.cms-photo figcaption) {
    text-align: center;
    font-size: 0.8rem;
    color: #888;
    font-style: italic;
    margin-top: 0.4rem;
  }

  /* ── cms-photo-row: multi-column photo grid ── */
  :global(.prose div.cms-photo-row) {
    display: grid;
    gap: 0.75rem;
    margin: 2rem 0;
    clear: both;
  }
  :global(.prose div.cms-photo-row[data-cols="2"]) { grid-template-columns: 1fr 1fr; }
  :global(.prose div.cms-photo-row[data-cols="3"]) { grid-template-columns: 1fr 1fr 1fr; }
  :global(.prose div.cms-photo-row[data-cols="4"]) { grid-template-columns: 1fr 1fr 1fr 1fr; }

  @media (max-width: 640px) {
    :global(.prose div.cms-photo-row) {
      grid-template-columns: 1fr !important;
    }
  }

  :global(.prose div.cms-photo-row figure) {
    margin: 0;
  }

  :global(.prose div.cms-photo-row img) {
    width: 100%;
    height: auto;
    border-radius: 10px;
    display: block;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.35);
    margin: 0;
  }

  :global(.prose div.cms-photo-row[data-aspect="landscape"] img) { aspect-ratio: 16 / 9; object-fit: cover; }
  :global(.prose div.cms-photo-row[data-aspect="square"] img)    { aspect-ratio: 1 / 1;  object-fit: cover; }
  :global(.prose div.cms-photo-row[data-aspect="portrait"] img)  { aspect-ratio: 3 / 4;  object-fit: cover; }

  :global(.prose div.cms-photo-row figcaption) {
    text-align: center;
    font-size: 0.75rem;
    color: #888;
    font-style: italic;
    margin-top: 0.35rem;
  }
</style>
